<?xml version="1.0" encoding="UTF-8"?>
<!--
  ext4-win-driver Burn bootstrapper.

  Wraps Product.msi together with the WinFsp MSI into a single .exe so end
  users don't have to install WinFsp by hand. Burn handles "already
  installed → skip" automatically via DetectCondition + the registry
  search below.

  Built by `installer/build.ps1` after Product.msi is produced. The script
  passes:
    -d Version=<x.y.z>             from Cargo.toml
    -d Ext4Msi=<path>              path to Product.msi just built
    -d WinFspMsi=<path>            path to the redistributable WinFsp MSI
    -d WinFspVersion=<x.y.z.b>     WinFsp's 4-part version (for DetectCondition)

  Stable bundle UpgradeCode — DO NOT regenerate, or major-upgrade chaining
  on the bundle itself breaks.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal">

  <Bundle
      Name="ext4-win-driver"
      Manufacturer="Antimatter Studios"
      Version="$(var.Version)"
      UpgradeCode="b6d4e8a1-3f29-4c7d-9e22-1a8c5d6f7e34"
      AboutUrl="https://github.com/antimatter-studios/ext4-win-driver"
      HelpUrl="https://winfsp.dev/">

    <!--
      WinFsp's MSI writes its 4-part version to
      HKLM\SOFTWARE\WOW6432Node\WinFsp\Version (32-bit view) — Burn reads
      it via util:RegistrySearchRef-style search. We use this both to
      decide whether to skip the WinFsp package (DetectCondition) and to
      gate "is it already new enough".
    -->
    <!--
      WiX 7 dropped the `Format` attribute on util:RegistrySearch — the
      raw value is what you get by default now. The Bitness="always32"
      hits the WoW6432Node view where WinFsp's installer writes its
      Version value.
    -->
    <util:RegistrySearch
        xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
        Id="WinFspInstalledVersion"
        Root="HKLM"
        Key="SOFTWARE\WOW6432Node\WinFsp"
        Value="Version"
        Result="value"
        Bitness="always32"
        Variable="WinFspInstalledVersion" />

    <!--
      hyperlinkLicense theme: clickable URL to the license rather than
      the license text. Both elements need explicit attrs:
        - <BootstrapperApplication Name="..."> identifies the BA payload
        - <bal:WixStandardBootstrapperApplication LicenseUrl="..."> is
          the actual license target the theme renders
    -->
    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
          Theme="hyperlinkLicense"
          LicenseUrl="https://www.gnu.org/licenses/gpl-3.0.html"
          ShowVersion="yes"
          SuppressOptionsUI="yes" />
    </BootstrapperApplication>

    <Chain>
      <!--
        WinFsp is installed first. DetectCondition: if the registry already
        reports a version >= the one we ship, skip. Permanent="yes" leaves
        WinFsp installed when ext4-win-driver is uninstalled (other apps
        may depend on it — sshfs-win, rclone, …).
      -->
      <!--
        Burn auto-detects MSI installation state via the package's
        ProductCode + Upgrade table; we don't add an explicit
        DetectCondition here. Permanent="yes" leaves WinFsp installed
        when ext4-win-driver is uninstalled (other apps may rely on
        it — sshfs-win, rclone, …).
      -->
      <MsiPackage
          Id="WinFsp"
          SourceFile="$(var.WinFspMsi)"
          DisplayName="WinFsp (Windows File System Proxy)"
          Description="User-mode filesystem framework — required by ext4-win-driver."
          Vital="yes"
          Permanent="yes"
          Visible="no"
          Compressed="yes" />

      <MsiPackage
          Id="Ext4WinDriver"
          SourceFile="$(var.Ext4Msi)"
          DisplayName="ext4-win-driver"
          Vital="yes"
          Visible="no"
          Compressed="yes" />
    </Chain>

  </Bundle>

</Wix>
